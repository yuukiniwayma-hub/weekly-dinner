#!/bin/bash
cd "$(dirname "$0")"
clear
echo "============================================"
echo "  献立アプリ：Cloudflare ログイン"
echo "============================================"
echo ""
echo "これからブラウザが開きます。"
echo "Cloudflareの画面で青い「Allow（許可）」ボタンを"
echo "クリックしてください。"
echo ""
echo "（Enterキーを押すと始まります）"
read -r _

npx --yes wrangler@4 login

echo ""
echo "--------------------------------------------"
echo "✅ ログインが終わったら、このウィンドウを閉じて"
echo "   Claudeに「ログインした」と伝えてください。"
echo "--------------------------------------------"
read -p "Enterキーで閉じます..." _
